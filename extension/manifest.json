{
  "manifest_version": 3,
  "name": "CC98 Smart Search",
  "version": "0.1.0",
  "description": "A lightweight fuzzy search enhancer for CC98 topic search.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.cc98.org/*",
    "https://api.cc98.org/*"
  ],
  "action": {
    "default_title": "CC98 Smart Search",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.cc98.org/*"
      ],
      "js": [
        "teacher-lexicon.js",
        "lexicon.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
